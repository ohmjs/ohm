{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",

    // From the totaltypescript "Building for a Library in a Monorepo"
    // recommendation. See tsconfig.base.json for details.
    "declaration": true,
    "composite": true,
    "sourceMap": true,

    // Overrides of tsconfig.base.json
    "allowJs": true,

    // "DOM" for WebAssembly, see https://github.com/evanw/esbuild/issues/2388#issuecomment-1183836728
    "lib": ["ES2023", "DOM"]
    // [end overrides]
  },
  "include": [
    "package.json",
    "src/**/*",
    "test/**/*.ts",
    "scripts/**/*.ts",
    "build/ohmRuntime.wasm_sections.ts",
    "build/ohm-grammar-wasm.ts",
    "index.ts",
    "tsdown.config.ts"
  ],
  "exclude": ["test/_stage-1-cst.spec.ts"]
}
